# 한국투자증권 실전 계좌 정보 (봇 전용 격리 계좌)
HANTU_APP_KEY=your_hantu_app_key_here
HANTU_APP_SECRET=your_hantu_app_secret_here
HANTU_CANO=your_cano_8_digits (예: 12345678)
HANTU_ACNT_PRDT_CD=01

# 텔레그램 API 정보 (내 개인 계정 권한으로 속보 채널을 읽기 위함)
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# 개인 알림용 텔레그램 봇 정보 (보고서 및 매매 알림 전송용)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_MY_CHAT_ID=your_personal_chat_id_here